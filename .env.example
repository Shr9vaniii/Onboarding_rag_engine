# Copy to .env and fill in real values. Never commit .env.

# Required for query rewrite + multi-query decomposition
GROQ_API_KEY=

# Remote LoRA inference (Colab/ngrok or RunPod)
INFERENCE_URL=
# Optional shared secret for the generation server
INFERENCE_API_KEY=

# Redis Cloud answer cache (optional; pipeline works without it)
REDIS_URL=
CACHE_TTL_SECONDS=604800

# Optional overrides
REWRITE_MODEL=llama-3.1-8b-instant
DECOMPOSE_MODEL=llama-3.1-8b-instant
LORA_PATH=
BASE_MODEL=unsloth/Llama-3.1-8B-Instruct
